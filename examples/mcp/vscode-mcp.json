{
  "inputs": [
    {
      "type": "promptString",
      "id": "lawstronaut-mcp-bearer",
      "description": "Lawstronaut MCP bearer token (API key)",
      "password": true
    }
  ],
  "servers": {
    "lawstronautMcp": {
      "type": "http",
      "url": "https://mcp.lawstronaut.com",
      "headers": {
        "Authorization": "Bearer ${input:lawstronaut-mcp-bearer}"
      }
    }
  }
}
